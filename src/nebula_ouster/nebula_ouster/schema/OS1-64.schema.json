{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiDAR Ouster OS1-64 parameters.",
  "type": "object",
  "definitions": {
    "OS1-64": {
      "type": "object",
      "properties": {
        "host_ip": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/host_ip"
        },
        "sensor_ip": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/sensor_ip"
        },
        "data_port": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/data_port"
        },
        "imu_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "description": "Ouster IMU UDP port"
        },
        "packet_mtu_size": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/packet_mtu_size"
        },
        "launch_hw": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/launch_hw"
        },
        "setup_sensor": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/setup_sensor"
        },
        "frame_id": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/frame_id"
        },
        "diag_span": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/diag_span"
        },
        "scan_phase": {
          "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/scan_phase"
        },
        "min_range": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 10.0
        },
        "max_range": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 400.0
        },
        "columns_per_frame": {
          "type": "integer",
          "enum": [512, 1024, 2048]
        },
        "calibration_file": {
          "type": "string",
          "description": "Path to Ouster sensor_info JSON calibration file"
        },
        "sensor_model": {
          "$ref": "lidar_ouster.json#/definitions/sensor_model",
          "enum": ["OS1-64"]
        },
        "return_mode": {
          "$ref": "lidar_ouster.json#/definitions/return_mode"
        }
      },
      "required": [
        "host_ip", "sensor_ip", "data_port", "imu_port", "packet_mtu_size",
        "launch_hw", "setup_sensor", "frame_id", "diag_span", "scan_phase",
        "min_range", "max_range", "columns_per_frame", "sensor_model", "return_mode"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "/**": {
      "type": "object",
      "properties": {
        "ros__parameters": { "$ref": "#/definitions/OS1-64" }
      },
      "required": ["ros__parameters"],
      "additionalProperties": false
    }
  },
  "required": ["/**"],
  "additionalProperties": false
}
